{
  "include_roots_default": ["apps"],
  "code_extensions": [".py", ".js", ".mjs", ".css", ".html", ".sql", ".json"],
  "global_strip_substrings": [
    "[stage4]",
    "] START - attempt",
    "] CMD - ",
    "] OUT - ",
    "] GATE - ",
    "行业背景",
    "用户角色",
    "核心业务流程",
    "数据模型",
    "功能列表",
    "边界约束",
    "验收标准",
    "视觉风格关键词",
    "版本快照",
    "发布留痕",
    "资源清单",
    "交互摘要",
    "占位页面",
    "占位内容",
    "占位文本",
    "This file is generated by",
    "Auto-generated domain label/validation catalog",
    "FIELD_LABELS",
    "字段口径",
    "[padding]"
  ],
  "skip_file_name_prefixes": ["_auto"],
  "skip_file_rel_substrings": ["/_auto_"],
  "skip_file_rel_suffixes": ["/_auto_catalog.py"],
  "skip_file_content_substrings": [
    "FIELD_LABELS",
    "字段口径",
    "[padding]",
    "Auto-generated domain label/validation catalog"
  ]
}

